# OpenAI Compatible API 配置示例
# 复制此文件为 .env 并填入你的配置

# API 基础 URL
API_BASE_URL=https://api.chatanywhere.org/v1

# API 密钥
API_KEY=your-api-key-here

# 备用 API URL（可选）
BACKUP_API_BASE_URL=https://newapi.aicohere.tech/v1

# 使用的模型名称
MODEL_NAME=gpt-4o

# 其他支持的模型示例：
# MODEL_NAME=gpt-4-turbo
# MODEL_NAME=gpt-3.5-turbo
# MODEL_NAME=claude-sonnet-4-5-20250929-thinking
